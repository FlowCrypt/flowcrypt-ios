# fastlane/Fastfile
ENV["FASTLANE_EXPLICIT_OPEN_SIMULATOR"] = "1"
ENV["FASTLANE_XCODEBUILD_SETTINGS_TIMEOUT"] = "120"
ENV["FASTLANE_XCODE_LIST_TIMEOUT"] = "120"

default_platform(:ios)

platform :ios do

  desc "Build for UI tests"
  lane :build do
    gym(
      project: "FlowCrypt.xcodeproj",
      scheme: "Debug FlowCrypt",
      # device: "iPhone SE (3rd generation) (17.4)",
      derived_data_path: "/var/tmp/derived_data/FlowCrypt",
      # skip_detect_devices: true,
      # build_for_testing: true,
      sdk: "iphonesimulator", 
      skip_codesigning: true,
      xcargs: "ARCHS='x86_64 arm64' VALID_ARCHS='x86_64 arm64' -destination 'generic/platform=iOS Simulator' -skipPackagePluginValidation -skipMacroValidation",
      export_method: "development",
      skip_package_ipa: true,
      skip_archive: true,
      skip_profile_detection: true,
      clean: false
    )
  end

  desc "Run Swift tests"
  lane :test do
    scan(
      project: "FlowCrypt.xcodeproj",
      scheme: "FlowCryptAppTests",
      device: "iPhone SE (3rd generation) (17.4)",
      test_without_building: true,
      derived_data_path: "/var/tmp/derived_data/FlowCrypt",
      xcargs: "-skipPackagePluginValidation -skipMacroValidation",
      parallel_testing: false,
      disable_concurrent_testing: true
    )
  end

end

